# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Strong random token for the Vaultwarden /admin panel.
# Generate one with: openssl rand -base64 48
ADMIN_TOKEN=change_me_to_a_strong_random_value

# Public URL served by Caddy (must match the Caddyfile hostname).
# Caddy will automatically obtain a Let's Encrypt TLS certificate for this domain.
VAULT_DOMAIN=https://dev-uk.uk

# Set to true only when you want to allow new account registrations.
SIGNUPS_ALLOWED=false

# Enable WebSocket notifications (required for live vault sync).
WEBSOCKET_ENABLED=true
